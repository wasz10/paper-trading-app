# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic (for AI Trade Coach — Phase 6)
ANTHROPIC_API_KEY=sk-ant-your-key

# Site password gate (optional — leave empty to disable)
SITE_PASSWORD=

# Developer panel (set to "true" to enable /dev tools page)
DEV_PANEL_ENABLED=
# Restrict dev panel to specific emails (comma-separated, optional)
DEV_ALLOWED_EMAILS=

# Push notifications (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
